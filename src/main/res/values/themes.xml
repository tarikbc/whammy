<resources>
  <!-- DESIGN.md §9: dark-only theme, no values-night variant. -->
  <style name="Theme.Whammy" parent="android:Theme.Material.NoActionBar">
    <item name="android:windowBackground">@drawable/bg_stage</item>
    <item name="android:colorBackground">@color/stage_black</item>
    <item name="android:statusBarColor">@android:color/transparent</item>
    <item name="android:windowLightStatusBar">false</item>
    <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    <item name="android:colorPrimary">@color/star</item>
    <!-- DESIGN.md §9's colorSurface and colorError are AndroidX Material attributes
         with no framework equivalent, so they are intentionally NOT set here in this
         Gradle-free, framework-Material-themed (android:Theme.Material) build. Widgets
         that need those colors reference @color/surface / @color/fret_red directly. -->
  </style>
</resources>
