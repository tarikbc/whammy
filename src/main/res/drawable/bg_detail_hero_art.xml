<?xml version="1.0" encoding="utf-8"?>
<!--
  Hairline outline for the detail screen's 112dp hero album art
  (DESIGN.md §7.13: "112dp, r_md 16dp, edge_hair"). Same technique as
  art_hairline.xml (owned by another agent, scoped to the 56dp row
  thumbnail's r_sm radius) but at the hero's r_md radius, so this is a
  small standalone copy rather than an edit to that shared file.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
  <corners android:radius="@dimen/r_md" />
  <stroke android:width="1dp" android:color="@color/edge_hair" />
  <solid android:color="@android:color/transparent" />
</shape>
