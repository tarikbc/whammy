<?xml version="1.0" encoding="utf-8"?>
<!--
  Search field background (DESIGN.md §7.2 / §9):
    <layer-list>: <shape r_md> `surface_hi` + top sheen gradient item +
    `edge_top` line + <stroke> that swaps `edge_hair` -> `star` on focus
    via a nested <selector>.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

  <!-- 1. Base fill -->
  <item>
    <shape android:shape="rectangle">
      <corners android:radius="@dimen/r_md" />
      <solid android:color="@color/surface_hi" />
    </shape>
  </item>

  <!-- 2. Glass sheen: a whisper of lightening in the top ~40% -->
  <item>
    <shape android:shape="rectangle">
      <corners android:radius="@dimen/r_md" />
      <gradient
          android:type="linear"
          android:angle="270"
          android:startColor="#14FFFFFF"
          android:centerColor="#00FFFFFF"
          android:centerY="0.4"
          android:endColor="#00FFFFFF" />
    </shape>
  </item>

  <!-- 3. Top inner highlight — "lit from above" -->
  <item android:gravity="top|fill_horizontal" android:height="1dp">
    <shape android:shape="rectangle">
      <corners android:radius="@dimen/r_md" />
      <solid android:color="@color/edge_top" />
    </shape>
  </item>

  <!-- 4. Outline: hairline at rest, star on focus (DESIGN.md §7.2) -->
  <item>
    <selector>
      <item android:state_focused="true">
        <shape android:shape="rectangle">
          <corners android:radius="@dimen/r_md" />
          <stroke android:width="1.5dp" android:color="@color/star" />
          <solid android:color="@android:color/transparent" />
        </shape>
      </item>
      <item>
        <shape android:shape="rectangle">
          <corners android:radius="@dimen/r_md" />
          <stroke android:width="1dp" android:color="@color/edge_hair" />
          <solid android:color="@android:color/transparent" />
        </shape>
      </item>
    </selector>
  </item>

</layer-list>
