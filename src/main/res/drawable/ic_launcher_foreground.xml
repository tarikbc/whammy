<?xml version="1.0" encoding="utf-8"?>
<!--
  App icon foreground — "the W-dive" (DESIGN.md 2.3 / 2.4): a W built from
  a pitch-dive/tremolo waveform, one continuous star-power cyan line. No
  blur is available in a static VectorDrawable, so the three-layer glow
  (5.2) is faked by stacking the same stroke at decreasing width and
  increasing alpha: star_deep on the outside, fading through star, to a
  near-white hot core on top (the "chrome bevel" highlight). A faint
  fret-spectrum rim hint sits along the lower edge, per spec — quiet, not
  rainbow-noisy.

  108x108 viewport; the mark sits inside the centered 72dp safe zone
  (18..90 on both axes) with margin to spare.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

  <!-- Fret-spectrum rim hint along the lower edge — subtle, four short
       segments under the two dive troughs, cycling the fret rainbow. -->
  <path android:pathData="M25,79 L39.5,79" android:strokeColor="#2E3CE07B"
      android:strokeWidth="1.4" android:strokeLineCap="round" android:fillColor="#00000000" />
