<?xml version="1.0" encoding="utf-8"?>
<!--
  Persistent r_sm hairline outline for the album-art ImageView
  (DESIGN.md §7.3: "56dp rounded square, edge_hair hairline outline").
  Set as the ImageView's background so it stays visible once a real
  cover bitmap replaces the art_placeholder `src`.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
  <corners android:radius="@dimen/r_sm" />
  <stroke android:width="1dp" android:color="@color/edge_hair" />
  <solid android:color="@android:color/transparent" />
</shape>
