<?xml version="1.0" encoding="utf-8"?>
<!--
  Note button — IDLE / DOWNLOADING-placeholder state (DESIGN.md §7.4):
  hollow 2dp ring in the neutral `star` action accent — no per-row fret
  tinting (rows now lead with album art instead; fret colors are
  icon-only, DESIGN.md §1.1). Reused as-is for the DOWNLOADING
  placeholder (Task 9's ProgressRingView owns the actual cyan->blue
  sweep-arc visual, added as a further child of the note_button
  FrameLayout without any restructuring here).
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="oval">
  <stroke android:width="2dp" android:color="@color/star" />
  <solid android:color="@android:color/transparent" />
</shape>
