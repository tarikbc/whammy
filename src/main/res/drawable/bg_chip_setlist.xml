<?xml version="1.0" encoding="utf-8"?>
<!--
  Setlist badge chip background (DESIGN.md §7.10 chip shell, extended):
  same r_sm 12dp pill shape as bg_chip/bg_chip_video, but goes one step
  bolder than the video chip's hairline-only treatment — a faint `star`
  wash fill (not just a stroke) plus the `star` hairline, so the
  SETLIST chip reads as the most "look at me" badge in the row/detail
  chip set, per the "stand out a little" brief. Label text at the use
  site is also `star`-colored (not `text`, unlike the other chips) to
  reinforce it.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
  <solid android:color="#3D35E6E1" />
  <corners android:radius="@dimen/r_sm" />
  <stroke android:width="1dp" android:color="@color/star" />
</shape>
