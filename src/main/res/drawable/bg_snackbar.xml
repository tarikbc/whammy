<?xml version="1.0" encoding="utf-8"?>
<!--
  Snackbar card background (DESIGN.md §7.8 / §9 layer-list convention —
  same technique as bg_row.xml/bg_search.xml): surface_top fill, r_md
  16dp corners, a 1px edge_top top highlight ("lit from above"), and an
  edge_hair hairline outline. The soft edge_shadow lift comes from the
  view's own elevation (set in view_snackbar.xml), not from this
  drawable.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

  <!-- 1. Base fill -->
  <item>
    <shape android:shape="rectangle">
      <corners android:radius="@dimen/r_md" />
      <solid android:color="@color/surface_top" />
    </shape>
  </item>

  <!-- 2. Top inner highlight — "lit from above" -->
  <item android:gravity="top|fill_horizontal" android:height="1dp">
    <shape android:shape="rectangle">
      <corners android:radius="@dimen/r_md" />
      <solid android:color="@color/edge_top" />
    </shape>
  </item>

  <!-- 3. Hairline outline -->
  <item>
    <shape android:shape="rectangle">
      <corners android:radius="@dimen/r_md" />
      <stroke android:width="1dp" android:color="@color/edge_hair" />
      <solid android:color="@android:color/transparent" />
    </shape>
  </item>

</layer-list>
