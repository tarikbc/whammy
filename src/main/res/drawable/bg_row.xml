<?xml version="1.0" encoding="utf-8"?>
<!--
  Result row background (DESIGN.md §7.3 / §9):
    <layer-list>: <shape r_lg> solid `surface` + top inset 1px `edge_top`
    line + <stroke> `edge_hair`.
  The row is nearly flat: no heavy shadow, just a lit top edge and a
  hairline outline stepping it off the stage background.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

  <!-- 1. Base fill -->
  <item>
    <shape android:shape="rectangle">
      <corners android:radius="@dimen/r_lg" />
      <solid android:color="@color/surface" />
    </shape>
  </item>

  <!-- 2. Top inner highlight — "lit from above" -->
  <item android:gravity="top|fill_horizontal" android:height="1dp">
    <shape android:shape="rectangle">
      <corners android:radius="@dimen/r_lg" />
      <solid android:color="@color/edge_top" />
    </shape>
  </item>

  <!-- 3. Hairline outline -->
  <item>
    <shape android:shape="rectangle">
      <corners android:radius="@dimen/r_lg" />
      <stroke android:width="1dp" android:color="@color/edge_hair" />
      <solid android:color="@android:color/transparent" />
    </shape>
  </item>

</layer-list>
