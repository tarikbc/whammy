<?xml version="1.0" encoding="utf-8"?>
<!--
  Instrument badge: guitar. DESIGN.md §7.7/§7.10: 24 grid, 2dp stroke,
  monochrome, must read as an actual guitar silhouette at chip size (not
  an abstract mark). A waisted, single closed body outline (hourglass
  bout curves, not a bare circle) + a diagonal neck/headstock + a small
  sound-hole, so it's distinguishable from ic_inst_bass's blockier body
  and straight-up neck at a glance.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
  <!-- Waisted body silhouette: upper bout -> waist indent -> lower bout -> waist indent -> back to start. -->
  <path
      android:pathData="M11,10 C8,10 6,11.3 6,13.3 C6,14.6 7,15.2 6.6,16.6 C6.2,18.2 7.2,20.5 10,20.5 C12.8,20.5 13.8,18.2 13.4,16.6 C13,15.2 14,14.6 14,13.3 C14,11.3 12.5,10 11,10 Z"
      android:strokeColor="#FFFFFF"
      android:strokeWidth="2"
      android:strokeLineCap="round"
      android:strokeLineJoin="round"
      android:fillColor="#00000000" />
  <!-- Sound hole -->
  <path
      android:pathData="M8.7,15.3 a1.3,1.3 0 1,0 2.6,0 a1.3,1.3 0 1,0 -2.6,0"
      android:strokeColor="#FFFFFF"
      android:strokeWidth="1.5"
      android:strokeLineCap="round"
      android:strokeLineJoin="round"
      android:fillColor="#00000000" />
  <!-- Neck + headstock cap -->
  <path
      android:pathData="M11.5,10.3 L18,3 M16,2.3 L19,4.3"
      android:strokeColor="#FFFFFF"
      android:strokeWidth="2"
      android:strokeLineCap="round"
      android:strokeLineJoin="round"
      android:fillColor="#00000000" />
</vector>
