<?xml version="1.0" encoding="utf-8"?>
<!--
  Filter chip background — unselected (DESIGN.md §7.11): surface_hi fill,
  r_sm 12dp pill corners, edge_hair hairline. Same shell language as the
  row badge chips (bg_chip), scoped separately since this task owns
  drawable/ filter-chip assets specifically and the search-result badge
  chips (bg_chip) belong to a different task's file scope.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
  <solid android:color="@color/surface_hi" />
  <corners android:radius="@dimen/r_sm" />
  <stroke android:width="1dp" android:color="@color/edge_hair" />
</shape>
