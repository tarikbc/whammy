<?xml version="1.0" encoding="utf-8"?>
<!--
  Lane-light (DESIGN.md §7.3 / §9): 3dp rounded bar, vertical fade
  (brighter at top), tinted per row via `setBackgroundTintList` in
  ResultsAdapter using `fret_*` selected by `position % 5`.

  The gradient here is white with a fading alpha (100% -> 40%), not a
  hue — SRC_IN tinting (the ImageView/View background tint default)
  replaces the RGB with the fret color while preserving this alpha
  ramp, producing "brighter at top" per the row's identity color.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
  <corners android:radius="2dp" />
  <gradient
      android:angle="270"
      android:startColor="#FFFFFFFF"
      android:endColor="#66FFFFFF" />
  <size android:width="@dimen/lane_light_width" />
</shape>
