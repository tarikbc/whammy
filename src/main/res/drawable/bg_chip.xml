<?xml version="1.0" encoding="utf-8"?>
<!--
  Badge chip background (DESIGN.md §7.10): surface_hi fill, r_sm 12dp
  pill corners, edge_hair hairline. The default chip shell used for the
  instrument cluster, duration, PRO and MOD chips. The video chip swaps
  this out for bg_chip_video (same shape, star hairline) since it's the
  one badge that earns color.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
  <solid android:color="@color/surface_hi" />
  <corners android:radius="@dimen/r_sm" />
  <stroke android:width="1dp" android:color="@color/edge_hair" />
</shape>
