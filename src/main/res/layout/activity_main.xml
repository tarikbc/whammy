<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical">

  <!-- App bar (DESIGN.md §7.1/§7.1b): wordmark leading, a single custom
       `library` glyph trailing (`text_lo`) that opens the Library
       screen. The Library screen itself is a later task (R4); for now
       the glyph is real and tappable, wired to a placeholder Toast in
       MainActivity. -->
  <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="@dimen/app_bar_height"
      android:layout_marginTop="@dimen/space_8"
      android:orientation="horizontal"
      android:gravity="center_vertical"
      android:paddingStart="@dimen/screen_padding_h"
      android:paddingEnd="@dimen/space_8">

    <TextView
        style="@style/Text.Wordmark"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="26sp"
        android:text="WHAMMY" />

    <ImageView
        android:id="@+id/library_button"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:padding="7dp"
        android:src="@drawable/ic_library"
        android:tint="@color/text_lo"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/library_button_desc" />
  </LinearLayout>

  <!-- Search field — the strike zone (DESIGN.md §7.2). Executing the
       search itself (calling EncoreApi + populating the list) is
       Task 10 — this just makes the field real: focusable, raises the
       keyboard, and shows/hides its own clear button. -->
  <LinearLayout
      android:id="@+id/search_field"
      android:layout_width="match_parent"
      android:layout_height="@dimen/search_field_height"
      android:layout_marginStart="@dimen/screen_padding_h"
      android:layout_marginEnd="@dimen/screen_padding_h"
      android:layout_marginTop="@dimen/space_16"
      android:orientation="horizontal"
      android:gravity="center_vertical"
      android:paddingStart="@dimen/space_16"
      android:paddingEnd="@dimen/space_16"
      android:background="@drawable/bg_search"
      android:addStatesFromChildren="true">

    <ImageView
        android:layout_width="19dp"
        android:layout_height="19dp"
        android:src="@drawable/ic_search"
        android:tint="@color/text_lo" />

    <EditText
        android:id="@+id/search_input"
        style="@style/Text.SearchInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/space_12"
        android:background="@null"
        android:hint="@string/search_hint"
        android:inputType="text"
        android:imeOptions="actionSearch"
        android:singleLine="true"
        android:maxLines="1" />

    <ImageView
        android:id="@+id/search_clear"
        android:layout_width="19dp"
        android:layout_height="19dp"
        android:src="@drawable/ic_clear"
        android:tint="@color/text_lo"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true" />
  </LinearLayout>

  <!-- Filter chip rail (DESIGN.md §7.11): instrument single-select
       (server-side, narrows the search body's `instrument` field) plus a
       client-side Video toggle. Hidden until there is a search context
       (MainActivity shows it once a search has run) so the first-launch
       empty state stays uncluttered. Chip shell = bg_chip_filter /
       bg_chip_filter_selected (surface_hi, r_sm, edge_hair; selected =
       star 1.5dp stroke) per §7.11 — label color (text / text_hi) is
       swapped in code on selection. -->
  <HorizontalScrollView
      android:id="@+id/filter_rail"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/space_12"
      android:visibility="gone"
      android:scrollbars="none"
      android:clipToPadding="false"
      android:paddingStart="@dimen/screen_padding_h"
      android:paddingEnd="@dimen/screen_padding_h">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

      <TextView
          android:id="@+id/chip_instrument_guitar"
          style="@style/Text.Charter"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:background="@drawable/bg_chip_filter"
          android:textColor="@color/text"
          android:paddingStart="@dimen/space_12"
          android:paddingEnd="@dimen/space_12"
          android:paddingTop="@dimen/space_8"
          android:paddingBottom="@dimen/space_8"
          android:clickable="true"
          android:focusable="true"
          android:text="Guitar" />

      <TextView
          android:id="@+id/chip_instrument_bass"
          style="@style/Text.Charter"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginStart="@dimen/badge_gap"
          android:background="@drawable/bg_chip_filter"
          android:textColor="@color/text"
          android:paddingStart="@dimen/space_12"
          android:paddingEnd="@dimen/space_12"
          android:paddingTop="@dimen/space_8"
          android:paddingBottom="@dimen/space_8"
          android:clickable="true"
          android:focusable="true"
          android:text="Bass" />

      <TextView
          android:id="@+id/chip_instrument_drums"
          style="@style/Text.Charter"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginStart="@dimen/badge_gap"
          android:background="@drawable/bg_chip_filter"
          android:textColor="@color/text"
          android:paddingStart="@dimen/space_12"
          android:paddingEnd="@dimen/space_12"
          android:paddingTop="@dimen/space_8"
          android:paddingBottom="@dimen/space_8"
          android:clickable="true"
          android:focusable="true"
          android:text="Drums" />

      <TextView
          android:id="@+id/chip_instrument_keys"
          style="@style/Text.Charter"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginStart="@dimen/badge_gap"
          android:background="@drawable/bg_chip_filter"
          android:textColor="@color/text"
          android:paddingStart="@dimen/space_12"
          android:paddingEnd="@dimen/space_12"
          android:paddingTop="@dimen/space_8"
          android:paddingBottom="@dimen/space_8"
          android:clickable="true"
          android:focusable="true"
          android:text="Keys" />

      <TextView
          android:id="@+id/chip_instrument_vocals"
          style="@style/Text.Charter"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginStart="@dimen/badge_gap"
          android:background="@drawable/bg_chip_filter"
          android:textColor="@color/text"
          android:paddingStart="@dimen/space_12"
          android:paddingEnd="@dimen/space_12"
          android:paddingTop="@dimen/space_8"
          android:paddingBottom="@dimen/space_8"
          android:clickable="true"
          android:focusable="true"
          android:text="Vocals" />

      <!-- Divider gap between the (server-side, single-select) instrument
           group and the (client-side) Video toggle: extra space reads as
           a deliberate group break rather than just another chip. -->
      <View
          android:layout_width="@dimen/space_12"
          android:layout_height="1dp" />

      <TextView
          android:id="@+id/chip_video"
          style="@style/Text.Charter"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:background="@drawable/bg_chip_filter"
          android:textColor="@color/text"
          android:paddingStart="@dimen/space_12"
          android:paddingEnd="@dimen/space_12"
          android:paddingTop="@dimen/space_8"
          android:paddingBottom="@dimen/space_8"
          android:clickable="true"
          android:focusable="true"
          android:text="Video" />
    </LinearLayout>
  </HorizontalScrollView>

  <!-- RecyclerView is added into this container programmatically by
       MainActivity (not declared here as an XML tag) — see
       ResultsAdapter / build.sh for why. empty_state is a
       sibling child stacked on top of it (DESIGN.md §7.5): MainActivity
       toggles between the two, swapping empty_state's headline/sub
       between the first-launch copy (default, below) and the
       no-results copy for a query that came back empty. -->
  <FrameLayout
      android:id="@+id/results_container"
      android:layout_width="match_parent"
      android:layout_height="0dp"
      android:layout_weight="1">

    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="@dimen/screen_padding_h"
        android:paddingEnd="@dimen/screen_padding_h">

      <!-- TODO promote "Find your setlist" to strings.xml -->
      <TextView
          android:id="@+id/empty_headline"
          style="@style/Text.HeroHeadline"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:gravity="center"
          android:text="Find your setlist" />

      <!-- TODO promote "Search the Encore database..." to strings.xml -->
      <TextView
          android:id="@+id/empty_sub"
          style="@style/Text.Body"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginTop="@dimen/space_8"
          android:gravity="center"
          android:text="Search the Encore database and drop songs straight into Clone Hero." />
    </LinearLayout>
  </FrameLayout>
</LinearLayout>
